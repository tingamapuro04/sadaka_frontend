# Public API base (baked into the client at build time)
VITE_API_BASE_URL=http://localhost:3000

# Withdrawal UI mode for church admins
VITE_WITHDRAWAL_MODE=instant

# Platform (Sadaka super-admin) login — not linked from public UI
# Bookmark this path (plus ?access= when key is set). Do not advertise to churches.
VITE_PLATFORM_LOGIN_PATH=/ops/login
# Optional soft gate: when set, login page requires ?access=<this value>
# VITE_PLATFORM_LOGIN_KEY=
